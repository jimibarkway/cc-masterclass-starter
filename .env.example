# Copy this file to .env.local and fill in your real values.
# Never commit .env.local. It is gitignored for a reason.

# --- Supabase (database + auth) ---
# Get these from your Supabase project: Settings > API.
# Use the NEW key format (sb_publishable_ / sb_secret_), not the legacy anon / service_role keys.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx   # safe for the browser
SUPABASE_SECRET_KEY=sb_secret_xxx                         # server only, treat it like a password

# --- Stripe (payments) ---
# Get these from the Stripe dashboard in Test mode first: Developers > API keys.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
# From `stripe listen` locally, or the webhook endpoint settings in production.
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- App ---
# Your local dev URL, then your real domain in production.
NEXT_PUBLIC_APP_URL=http://localhost:3000
